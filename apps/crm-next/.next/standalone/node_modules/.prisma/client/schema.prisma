generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["client", "crm", "audit"]
}

enum CrmDealStage {
  NOVO
  QUALIFICACAO
  ONBOARDING
  PRODUCAO
  ATIVO
  INADIMPLENTE
  CANCELADO

  @@map("deal_stage")
  @@schema("crm")
}

model Lead {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source    String       @db.VarChar(40)
  sourceRef String?      @map("source_ref") @db.VarChar(120)
  name      String       @db.VarChar(190)
  email     String?      @db.VarChar(190)
  phone     String?      @db.VarChar(30)
  interest  String?      @db.VarChar(120)
  payload   Json?
  stage     CrmDealStage @default(NOVO)
  owner     String?      @db.VarChar(120)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @default(now()) @map("updated_at")

  cards PipelineCard[]
  deals Deal[]

  @@map("leads")
  @@schema("crm")
}

model Organization {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legalName     String   @map("legal_name") @db.VarChar(220)
  tradeName     String?  @map("trade_name") @db.VarChar(220)
  billingEmail  String   @map("billing_email") @db.VarChar(190)
  whatsapp      String?  @db.VarChar(30)
  domain        String?  @db.VarChar(190)
  cpfCnpj       String   @map("cpf_cnpj") @db.VarChar(30)
  billingStreet String?  @map("billing_street") @db.VarChar(220)
  billingNumber String?  @map("billing_number") @db.VarChar(40)
  billingCity   String?  @map("billing_city") @db.VarChar(120)
  billingState  String?  @map("billing_state") @db.VarChar(8)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")

  subscriptions          Subscription[]
  projects               Project[]
  subscriptionItems      SubscriptionItem[]
  projectOperationStates ProjectOperationState[]
  signupSessions         SignupSession[]
  proposals              ProposalAvulsa[]
  cards                  PipelineCard[]
  deals                  Deal[]
  financialEntries       FinancialEntry[]
  collectionActions      CollectionAction[]

  @@map("organizations")
  @@schema("client")
}

model Plan {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String   @unique @db.VarChar(40)
  name         String   @db.VarChar(120)
  monthlyPrice Decimal  @map("monthly_price") @db.Decimal(10, 2)
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  subscriptions     Subscription[]
  subscriptionItems SubscriptionItem[]

  @@map("plans")
  @@schema("client")
}

model Subscription {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId          String    @map("organization_id") @db.Uuid
  planId                  String    @map("plan_id") @db.Uuid
  asaasCustomerId         String?   @map("asaas_customer_id") @db.VarChar(80)
  asaasSubscriptionId     String?   @map("asaas_subscription_id") @db.VarChar(80)
  status                  String    @default("PENDING") @db.VarChar(40)
  paymentMethod           String    @map("payment_method") @db.VarChar(20)
  priceOverride           Decimal?  @map("price_override") @db.Decimal(10, 2)
  consolidatedValue       Decimal?  @map("consolidated_value") @db.Decimal(10, 2)
  lastRecalcAt            DateTime? @map("last_recalc_at")
  billingProfileUpdatedAt DateTime? @map("billing_profile_updated_at")
  lastAsaasEventAt        DateTime? @map("last_asaas_event_at")
  nextDueDate             DateTime? @map("next_due_date") @db.Date
  graceUntil              DateTime? @map("grace_until") @db.Date
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @default(now()) @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])
  payments     Payment[]

  @@map("subscriptions")
  @@schema("client")
}

model Project {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  domain         String?  @db.VarChar(190)
  projectType    String   @map("project_type") @db.VarChar(40)
  status         String   @default("PENDING") @db.VarChar(30)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionItem  SubscriptionItem?
  operationState    ProjectOperationState?
  templateRevisions DealTemplateRevision[]
  approvals         DealClientApproval[]
  publishChecks     DealPublishCheck[]

  @@index([organizationId, status, createdAt])
  @@map("projects")
  @@schema("client")
}

model ProjectOperationState {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @unique @map("project_id") @db.Uuid
  dealId         String?  @map("deal_id") @db.Uuid
  stage          String   @default("briefing_pendente") @db.VarChar(80)
  ownerUserId    String?  @map("owner_user_id") @db.Uuid
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([organizationId, updatedAt])
  @@map("project_operation_state")
  @@schema("crm")
}

model SubscriptionItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @unique @map("project_id") @db.Uuid
  planId         String   @map("plan_id") @db.Uuid
  status         String   @default("PENDING") @db.VarChar(30)
  priceOverride  Decimal? @map("price_override") @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([organizationId, status, createdAt])
  @@map("subscription_items")
  @@schema("client")
}

model Payment {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId String    @map("subscription_id") @db.Uuid
  asaasPaymentId String?   @map("asaas_payment_id") @db.VarChar(80)
  amount         Decimal   @db.Decimal(10, 2)
  status         String    @db.VarChar(40)
  billingType    String?   @map("billing_type") @db.VarChar(20)
  dueDate        DateTime? @map("due_date") @db.Date
  paidAt         DateTime? @map("paid_at")
  rawPayload     Json?     @map("raw_payload")
  createdAt      DateTime  @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
  @@schema("client")
}

model BillingProfile {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  cardHolder     String?  @map("card_holder") @db.VarChar(190)
  cardLast4      String?  @map("card_last4") @db.VarChar(4)
  cardBrand      String?  @map("card_brand") @db.VarChar(40)
  expMonth       Int?     @map("exp_month") @db.SmallInt
  expYear        Int?     @map("exp_year") @db.SmallInt
  isValidated    Boolean  @default(false) @map("is_validated")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("billing_profiles")
  @@schema("client")
}

model TicketQueue {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId    String    @map("ticket_id") @db.Uuid
  queueName   String    @map("queue_name") @db.VarChar(60)
  slaDeadline DateTime? @map("sla_deadline")
  status      String    @default("NEW") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("ticket_queue")
  @@schema("crm")
}

model Task {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId      String?   @map("lead_id") @db.Uuid
  accountId   String?   @map("account_id") @db.Uuid
  title       String    @db.VarChar(220)
  taskType    String    @map("task_type") @db.VarChar(60)
  slaDeadline DateTime? @map("sla_deadline")
  status      String    @default("PENDING") @db.VarChar(20)
  assignee    String?   @db.VarChar(120)
  details     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  @@map("tasks")
  @@schema("crm")
}

model WebhookEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider  String   @db.VarChar(30)
  eventId   String   @map("event_id") @db.VarChar(120)
  eventType String?  @map("event_type") @db.VarChar(120)
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([provider, eventId])
  @@map("webhook_events")
  @@schema("client")
}

model EmailQueue {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  emailTo        String    @map("email_to") @db.VarChar(190)
  subject        String    @db.VarChar(220)
  body           String
  attachments    Json?     @map("attachments")
  status         String    @default("PENDING") @db.VarChar(20)
  createdAt      DateTime  @default(now()) @map("created_at")
  processedAt    DateTime? @map("processed_at")

  @@map("email_queue")
  @@schema("crm")
}

model Pipeline {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(160)
  kind        String   @db.VarChar(30)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  stages PipelineStage[]
  cards  PipelineCard[]
  deals  Deal[]

  @@map("pipeline")
  @@schema("crm")
}

model PipelineStage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipelineId String   @map("pipeline_id") @db.Uuid
  code       String   @db.VarChar(80)
  name       String   @db.VarChar(120)
  stageOrder Int      @map("stage_order")
  slaHours   Int?     @map("sla_hours")
  isTerminal Boolean  @default(false) @map("is_terminal")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

  pipeline Pipeline       @relation(fields: [pipelineId], references: [id])
  cards    PipelineCard[]
  deals    Deal[]

  @@unique([pipelineId, code])
  @@map("pipeline_stage")
  @@schema("crm")
}

model PipelineCard {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipelineId        String    @map("pipeline_id") @db.Uuid
  stageId           String    @map("stage_id") @db.Uuid
  leadId            String?   @map("lead_id") @db.Uuid
  organizationId    String?   @map("organization_id") @db.Uuid
  proposalId        String?   @map("proposal_id") @db.Uuid
  title             String    @db.VarChar(220)
  contactName       String?   @map("contact_name") @db.VarChar(190)
  contactEmail      String?   @map("contact_email") @db.VarChar(190)
  contactPhone      String?   @map("contact_phone") @db.VarChar(30)
  dealType          String    @map("deal_type") @db.VarChar(40)
  category          String    @db.VarChar(30)
  intent            String?   @db.VarChar(80)
  origin            String    @db.VarChar(50)
  valueCents        Int?      @map("value_cents")
  positionIndex     Int       @default(0) @map("position_index")
  lastInteractionAt DateTime? @map("last_interaction_at")
  slaDeadline       DateTime? @map("sla_deadline")
  status            String    @default("OPEN") @db.VarChar(30)
  metadata          Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @map("updated_at")

  pipeline     Pipeline        @relation(fields: [pipelineId], references: [id])
  stage        PipelineStage   @relation(fields: [stageId], references: [id])
  lead         Lead?           @relation(fields: [leadId], references: [id])
  organization Organization?   @relation(fields: [organizationId], references: [id])
  proposal     ProposalAvulsa? @relation(fields: [proposalId], references: [id])

  @@index([pipelineId, stageId, positionIndex])
  @@map("pipeline_card")
  @@schema("crm")
}

model Deal {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipelineId      String    @map("pipeline_id") @db.Uuid
  stageId         String    @map("stage_id") @db.Uuid
  leadId          String?   @map("lead_id") @db.Uuid
  organizationId  String?   @map("organization_id") @db.Uuid
  subscriptionId  String?   @map("subscription_id") @db.Uuid
  title           String    @db.VarChar(220)
  contactName     String?   @map("contact_name") @db.VarChar(190)
  contactEmail    String?   @map("contact_email") @db.VarChar(190)
  contactPhone    String?   @map("contact_phone") @db.VarChar(30)
  dealType        String    @map("deal_type") @db.VarChar(40)
  category        String    @db.VarChar(30)
  intent          String?   @db.VarChar(80)
  origin          String    @db.VarChar(50)
  planCode        String?   @map("plan_code") @db.VarChar(40)
  productCode     String?   @map("product_code") @db.VarChar(80)
  valueCents      Int?      @map("value_cents")
  positionIndex   Int       @default(0) @map("position_index")
  slaDeadline     DateTime? @map("sla_deadline")
  lifecycleStatus String    @default("OPEN") @map("lifecycle_status") @db.VarChar(20)
  isClosed        Boolean   @default(false) @map("is_closed")
  closedAt        DateTime? @map("closed_at")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")

  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id])
  stage        PipelineStage @relation(fields: [stageId], references: [id])
  lead         Lead?         @relation(fields: [leadId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  stageHistory           DealStageHistory[]
  operations             DealOperation[]
  documents              DealDocument[]
  activities             DealActivity[]
  agenda                 DealAgenda[]
  proposals              DealProposal[]
  promptRevisions        DealPromptRevision[]
  templateRevisions      DealTemplateRevision[]
  clientApprovals        DealClientApproval[]
  publishChecks          DealPublishCheck[]
  financialEntries       FinancialEntry[]
  collections            CollectionAction[]
  projectOperationStates ProjectOperationState[]

  @@index([pipelineId, stageId, positionIndex])
  @@index([lifecycleStatus, isClosed])
  @@index([dealType, category])
  @@map("deal")
  @@schema("crm")
}

model DealPromptRevision {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId         String   @map("deal_id") @db.Uuid
  version        Int
  promptText     String   @map("prompt_text")
  promptJson     Json?    @map("prompt_json")
  status         String   @default("DRAFT") @db.VarChar(20)
  requestedNotes String?  @map("requested_notes")
  createdBy      String?  @map("created_by") @db.VarChar(120)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, version])
  @@index([dealId, createdAt])
  @@map("deal_prompt_revision")
  @@schema("crm")
}

model DealTemplateRevision {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId      String   @map("deal_id") @db.Uuid
  projectId   String?  @map("project_id") @db.Uuid
  version     Int
  projectPath String   @map("project_path") @db.VarChar(500)
  entryFile   String   @map("entry_file") @db.VarChar(255)
  previewUrl  String?  @map("preview_url") @db.VarChar(500)
  sourceHash  String?  @map("source_hash") @db.VarChar(128)
  status      String   @default("GENERATED") @db.VarChar(40)
  generatedBy String?  @map("generated_by") @db.VarChar(120)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  deal          Deal                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  project       Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  approvals     DealClientApproval[]
  publishChecks DealPublishCheck[]

  @@unique([dealId, projectId, version])
  @@index([dealId, projectId, createdAt])
  @@index([dealId, createdAt])
  @@map("deal_template_revision")
  @@schema("crm")
}

model DealClientApproval {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId             String    @map("deal_id") @db.Uuid
  projectId          String?   @map("project_id") @db.Uuid
  templateRevisionId String    @map("template_revision_id") @db.Uuid
  tokenHash          String    @map("token_hash") @db.VarChar(128)
  expiresAt          DateTime  @map("expires_at")
  status             String    @default("PENDING") @db.VarChar(30)
  clientNote         String?   @map("client_note")
  actedAt            DateTime? @map("acted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @map("updated_at")

  deal             Deal                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  project          Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  templateRevision DealTemplateRevision @relation(fields: [templateRevisionId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([dealId, projectId, createdAt])
  @@index([dealId, createdAt])
  @@map("deal_client_approval")
  @@schema("crm")
}

model DealPublishCheck {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId             String   @map("deal_id") @db.Uuid
  projectId          String?  @map("project_id") @db.Uuid
  templateRevisionId String   @map("template_revision_id") @db.Uuid
  targetDomain       String?  @map("target_domain") @db.VarChar(255)
  expectedHash       String?  @map("expected_hash") @db.VarChar(128)
  lastLiveHash       String?  @map("last_live_hash") @db.VarChar(128)
  lastHttpStatus     Int?     @map("last_http_status")
  matches            Boolean  @default(false)
  checkedAt          DateTime @default(now()) @map("checked_at")

  deal             Deal                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  project          Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  templateRevision DealTemplateRevision @relation(fields: [templateRevisionId], references: [id], onDelete: Cascade)

  @@index([dealId, projectId, checkedAt])
  @@index([dealId, checkedAt])
  @@index([templateRevisionId, checkedAt])
  @@map("deal_publish_check")
  @@schema("crm")
}

model DealStageHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId      String   @map("deal_id") @db.Uuid
  fromStageId String?  @map("from_stage_id") @db.Uuid
  toStageId   String   @map("to_stage_id") @db.Uuid
  changedBy   String?  @map("changed_by") @db.VarChar(120)
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
  @@map("deal_stage_history")
  @@schema("crm")
}

model DealOperation {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId        String    @map("deal_id") @db.Uuid
  operationType String    @map("operation_type") @db.VarChar(20)
  stageCode     String    @map("stage_code") @db.VarChar(80)
  stageName     String    @map("stage_name") @db.VarChar(120)
  stageOrder    Int       @map("stage_order")
  status        String    @default("ACTIVE") @db.VarChar(20)
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  updatedAt     DateTime  @default(now()) @map("updated_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, stageOrder])
  @@map("deal_operation")
  @@schema("crm")
}

model DealDocument {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId      String   @map("deal_id") @db.Uuid
  fileName    String   @map("file_name") @db.VarChar(255)
  storagePath String   @map("storage_path") @db.VarChar(500)
  mimeType    String?  @map("mime_type") @db.VarChar(120)
  sizeBytes   BigInt?  @map("size_bytes")
  uploadedBy  String?  @map("uploaded_by") @db.VarChar(120)
  createdAt   DateTime @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
  @@map("deal_document")
  @@schema("crm")
}

model DealActivity {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId       String   @map("deal_id") @db.Uuid
  activityType String   @map("activity_type") @db.VarChar(60)
  content      String
  metadata     Json?
  createdBy    String?  @map("created_by") @db.VarChar(120)
  createdAt    DateTime @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
  @@map("deal_activity")
  @@schema("crm")
}

model DealAgenda {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId      String   @map("deal_id") @db.Uuid
  title       String   @db.VarChar(220)
  description String?
  dueAt       DateTime @map("due_at")
  status      String   @default("OPEN") @db.VarChar(20)
  createdBy   String?  @map("created_by") @db.VarChar(120)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, dueAt])
  @@map("deal_agenda")
  @@schema("crm")
}

model DealProposal {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId     String   @map("deal_id") @db.Uuid
  title      String   @db.VarChar(220)
  scope      String?
  snapshot   Json?
  status     String   @default("DRAFT") @db.VarChar(40)
  valueCents Int?     @map("value_cents")
  pdfPath    String?  @map("pdf_path") @db.VarChar(500)
  createdBy  String?  @map("created_by") @db.VarChar(120)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

