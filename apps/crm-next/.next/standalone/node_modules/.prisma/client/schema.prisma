  post    SocialInstagramPost?    @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([accountId, createdAt])
  @@index([postId, createdAt])
  @@map("social_instagram_log")
  @@schema("crm")
}

